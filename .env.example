# Groq is the ONLY supported LLM provider for this project.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# LangSmith tracing/observability. Modern LANGSMITH_* names are preferred;
# legacy LANGCHAIN_* names are also read for backward compatibility. Tracing
# is gracefully disabled if no key is present, regardless of this flag.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=property-investment-advisor

# Risk-based routing threshold (0-100) — also used by the Guardrail Agent
RISK_HUMAN_REVIEW_THRESHOLD=75

# Guardrail confidence threshold (0-1) — recommendations below this require human review
GUARDRAIL_CONFIDENCE_THRESHOLD=0.70

# Retry caps for routing loops
MAX_DATA_RETRIES=2
MAX_REANALYSIS_RETRIES=2

# Set to "true" to auto-approve human review (used by evals / demo / non-interactive runs)
AUTO_APPROVE_HUMAN_REVIEW=false

# FastAPI server settings
API_HOST=0.0.0.0
API_PORT=8000
